{
  "name": "kyotei-ev-assistant",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Kyotei (boat-race) EV assistant — buy or skip, in 3 seconds.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/tdz-audit.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "tdz": "node scripts/tdz-audit.mjs",
    "test:sanity": "node scripts/sanity-check.mjs",
    "test:pnl": "node scripts/pnl-check.mjs",
    "test:storage": "node scripts/storage-integrity-check.mjs",
    "test:cloud": "node scripts/cloud-sync-safety-check.mjs",
    "test:jst": "node scripts/jst-date-check.mjs",
    "test:label": "node scripts/label-quality-check.mjs",
    "test:save": "node scripts/save-roundtrip-check.mjs",
    "test:preclose": "node scripts/preclose-gate-check.mjs",
    "test:styles": "node scripts/style-divergence-check.mjs",
    "test:verify": "node scripts/verification-log-check.mjs",
    "test:immutable": "node scripts/immutable-log-check.mjs",
    "test:detail": "node scripts/detail-snapshot-check.mjs",
    "test:separation": "node scripts/style-separation-check.mjs",
    "test:cloudstyle": "node scripts/cloud-style-roundtrip-check.mjs",
    "test:racelinks": "node scripts/race-links-check.mjs",
    "test:all": "npm run tdz && npm run test:sanity && npm run test:pnl && npm run test:storage && npm run test:cloud && npm run test:jst && npm run test:label && npm run test:save && npm run test:preclose && npm run test:styles && npm run test:verify && npm run test:immutable && npm run test:detail && npm run test:separation && npm run test:cloudstyle && npm run test:racelinks",
    "check": "npm run test:all && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "cheerio": "^1.0.0-rc.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  }
}
